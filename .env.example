# ─────────────────────────────────────────────────────────────
# THD HR Control Center — Environment Variables
# Copy this file to .env and fill in your real values
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://thd_user:thd_password@localhost:5432/thd_hr

# ── JWT Security ─────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=thd-hr-secret-key-change-in-production-2025
TOKEN_EXPIRE_HOURS=24

# ── Email (SMTP) ──────────────────────────────────────────────
# Set EMAIL_ENABLED=true to actually send emails
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hr@thd.de
SMTP_PASS=your-gmail-app-password
FROM_NAME=THD Human Resources

# ── App ───────────────────────────────────────────────────────
# Restrict CORS to your frontend domain in production
CORS_ORIGINS=*
